# Database (used by docker-compose variable interpolation)
POSTGRES_DB=fmcg_intelligence
POSTGRES_USER=fmcg
POSTGRES_PASSWORD=fmcg_secret
DATABASE_URL=postgresql+asyncpg://fmcg:fmcg_secret@db:5432/fmcg_intelligence
DATABASE_URL_SYNC=postgresql://fmcg:fmcg_secret@db:5432/fmcg_intelligence

# Redis
REDIS_URL=redis://localhost:6379/0

# API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxx
WORLD_BANK_API_URL=https://api.worldbank.org/v2
FAO_API_URL=https://www.fao.org/faostat/api/v1

# ERP Integration
ERP_BASE_URL=http://localhost:8080/api
ERP_API_KEY=erp-api-key-here
ERP_SYNC_INTERVAL_MINUTES=15
ERP_WEBHOOK_SECRET=

# POS Integration
POS_BASE_URL=http://localhost:9090/api
POS_API_KEY=pos-api-key-here
POS_SYNC_INTERVAL_MINUTES=5
POS_WEBHOOK_SECRET=

# Application
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Lebanon-specific
DEFAULT_CURRENCY=USD
SECONDARY_CURRENCY=LBP
LBP_EXCHANGE_RATE=89500

# WhatsApp Business API
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_RECIPIENTS=[]

# Email / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=intelligence@fmcg-platform.com
EMAIL_RECIPIENTS=[]

# Slack
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#intelligence-alerts

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dokploy Deployment
BACKEND_DOMAIN=api.yourdomain.com
FRONTEND_DOMAIN=app.yourdomain.com
